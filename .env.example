# Railway provee DATABASE_URL automaticamente
# SECRET_KEY se genera automaticamente si no se define
# PHOTOS_DIR, EXAMENES_DIR, DOCS_DIR se pueden sobreescribir

# Para S3 (opcional - si no se configura, usa almacenamiento local):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_S3_ENDPOINT=  # opcional, para DigitalOcean Spaces u otros compatibles con S3
